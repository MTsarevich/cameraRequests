# On Vercel, set these in: Project → Settings → Environment Variables.
# For local typecheck/tests they are not required.

# Shared secret the website must send in the X-Ingest-Secret header.
# Generate with: openssl rand -hex 32
INGEST_SECRET=replace-me

# Shared secret the cron pinger (cron-job.org) must send in the X-Cron-Secret header.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-me

# Firebase service account. Either the raw JSON, or (recommended) base64 of it.
# Get it: Firebase Console -> Project settings -> Service accounts -> Generate new private key
# Encode:  base64 -i serviceAccount.json | pbcopy
FIREBASE_SERVICE_ACCOUNT=replace-me
