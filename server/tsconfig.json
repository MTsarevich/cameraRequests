{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "lib": ["es2022"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["api", "src", "test"],
  "exclude": ["node_modules"]
}
